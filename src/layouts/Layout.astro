---
import "../styles/globals.css";

interface Props {
  locale?: string;
  title?: string;
}

const { locale = "en", title = "Open Money Tracker" } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#D95C9D" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <script is:inline>
      (function() {
        try {
          const localeCookie = document.cookie.match(/(?:^|;\s*)omt_locale=([^;]*)/);
          const localeStorage = localStorage.getItem("omt:locale");
          const locale = localeCookie?.[1] || localeStorage;
          if (locale === "en" || locale === "es") {
            document.documentElement.lang = locale;
          }

          const theme = localStorage.getItem("omt:theme");
          if (theme && ["light", "dark", "atom", "sky", "ocean"].includes(theme)) {
            document.documentElement.classList.add(theme);
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body>
    <div class="page-background" aria-hidden="true">
      <div class="finance-pattern">
        <svg
          class="finance-chart-right"
          viewBox="0 0 400 280"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <path
            d="M0 230 C40 210, 80 190, 130 165 C180 140, 230 115, 280 85 C330 60, 360 45, 400 35"
            fill="none"
            stroke="var(--background-accent-secondary)"
            stroke-width="2"
            stroke-linecap="round"
            opacity="0.55"
          />
          <path
            d="M0 230 C40 210, 80 190, 130 165 C180 140, 230 115, 280 85 C330 60, 360 45, 400 35"
            fill="none"
            stroke="var(--background-accent-secondary)"
            stroke-width="5"
            stroke-linecap="round"
            opacity="0.1"
          />
          <rect x="36"  y="215" width="7" height="24" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.28" />
          <rect x="68"  y="205" width="7" height="34" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.34" />
          <rect x="100" y="198" width="7" height="42" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.30" />
          <rect x="132" y="185" width="7" height="56" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.36" />
          <rect x="164" y="178" width="7" height="62" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.32" />
          <rect x="196" y="162" width="7" height="78" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.38" />
          <rect x="228" y="150" width="7" height="88" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.40" />
          <rect x="260" y="138" width="7" height="98" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.38" />
          <rect x="292" y="122" width="7" height="110" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.34" />
          <rect x="324" y="110" width="7" height="118" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.30" />
          <rect x="356" y="100" width="7" height="124" rx="1.5" fill="var(--background-accent-secondary)" opacity="0.26" />
        </svg>
        <svg
          class="finance-chart-left"
          viewBox="0 0 300 200"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <path
            d="M0 160 C50 155, 100 148, 150 130 C200 110, 240 95, 280 75 C290 68, 295 65, 300 62"
            fill="none"
            stroke="var(--background-accent-primary)"
            stroke-width="2"
            stroke-linecap="round"
            opacity="0.45"
          />
          <path
            d="M0 160 C50 155, 100 148, 150 130 C200 110, 240 95, 280 75 C290 68, 295 65, 300 62"
            fill="none"
            stroke="var(--background-accent-primary)"
            stroke-width="4"
            stroke-linecap="round"
            opacity="0.08"
          />
          <rect x="20"  y="165" width="5" height="20" rx="1" fill="var(--background-accent-primary)" opacity="0.25" />
          <rect x="45"  y="158" width="5" height="28" rx="1" fill="var(--background-accent-primary)" opacity="0.30" />
          <rect x="70"  y="150" width="5" height="36" rx="1" fill="var(--background-accent-primary)" opacity="0.32" />
          <rect x="95"  y="142" width="5" height="44" rx="1" fill="var(--background-accent-primary)" opacity="0.34" />
          <rect x="120" y="135" width="5" height="50" rx="1" fill="var(--background-accent-primary)" opacity="0.36" />
          <rect x="145" y="128" width="5" height="56" rx="1" fill="var(--background-accent-primary)" opacity="0.34" />
          <rect x="170" y="118" width="5" height="62" rx="1" fill="var(--background-accent-primary)" opacity="0.32" />
          <rect x="195" y="110" width="5" height="68" rx="1" fill="var(--background-accent-primary)" opacity="0.30" />
          <rect x="220" y="100" width="5" height="74" rx="1" fill="var(--background-accent-primary)" opacity="0.26" />
          <rect x="245" y="92"  width="5" height="80" rx="1" fill="var(--background-accent-primary)" opacity="0.22" />
        </svg>
      </div>
    </div>
    <slot />
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
