---
import Layout from "../layouts/Layout.astro";
---

<Layout locale="en" title="404 — Open Money Tracker">
  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="text-center space-y-4">
      <h1 class="text-6xl font-bold text-foreground">404</h1>
      <p class="text-lg text-muted-foreground">Page not found.</p>
      <a href="/" class="inline-flex h-10 items-center rounded-lg bg-primary px-6 text-sm font-medium text-primary-foreground transition hover:bg-primary/90">
        Go home
      </a>
    </div>
  </main>
</Layout>
